# MossBase Environment Variables
# Copy this file to .env and fill in all values before running docker-compose.

MOSS_SERVER_PORT=8033
MOSS_SERVER_MODE=debug
MOSS_DATABASE_HOST=127.0.0.1
MOSS_DATABASE_PORT=3306
MOSS_DATABASE_USERNAME=root
MOSS_DATABASE_PASSWORD=
MOSS_DATABASE_DBNAME=mossbase

# REQUIRED: Set a strong random secret for JWT signing
JWT_SECRET=

MOSS_JWT_EXPIRY_HOURS=24
MOSS_LOG_LEVEL=info

# RAG Service
MOSS_RAG_ENABLED=false
MOSS_RAG_BASE_URL=http://127.0.0.1:8090

# REQUIRED: API key for RAG service authentication
RAG_API_KEY=

# OpenAI (for RAG embeddings)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# MCP Server
MCP_API_KEY=
MOSS_MCP_ENABLED=false
MOSS_MCP_TRANSPORT=stdio
MOSS_MCP_HTTP_PORT=8095
